<section class="calculator">
  <div class="container">
    <div class="calculator__card">
      <h2 class="calculator__title">{{ section.settings.heading }}</h2>
      <p class="calculator__subtitle">{{ section.settings.description }}</p>
      <form class="calculator__form" id="quote-calculator" data-price-per-sqm="{{ section.settings.price_per_sqm }}" data-min-price="{{ section.settings.min_price }}">
        <div class="calculator__row">
          <div class="calculator__field">
            <label for="calc-width">Width (cm)</label>
            <input type="number" id="calc-width" value="200" min="10" max="5000" class="input">
          </div>
          <div class="calculator__field">
            <label for="calc-height">Height (cm)</label>
            <input type="number" id="calc-height" value="100" min="10" max="3000" class="input">
          </div>
        </div>
        <div class="calculator__field">
          <label for="calc-qty">Quantity</label>
          <input type="number" id="calc-qty" value="1" min="1" max="999" class="input">
        </div>

        {% if section.settings.show_finishing %}
          <div class="calculator__field">
            <label for="calc-finishing">Finishing</label>
            <select id="calc-finishing" class="input">
              <option value="eyelets">Eyelets</option>
              <option value="hem-eyelets">Hem and eyelets</option>
              <option value="pole-pockets">Pole pockets</option>
            </select>
          </div>
        {% endif %}

        <div class="calculator__result">
          <span class="calculator__label">Estimated Total</span>
          <span class="calculator__price" id="calc-price">&pound;0.00</span>
          <span class="calculator__vat">Excludes VAT &amp; Delivery</span>
        </div>
        <a href="/pages/upload-artwork" class="btn btn--primary btn--lg calculator__btn">Upload Artwork to Order</a>
      </form>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Quote calculator",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Instant Quote"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Enter sizes in cm"
    },
    {
      "type": "text",
      "id": "price_per_sqm",
      "label": "Price per sq metre (£)",
      "default": "15.50"
    },
    {
      "type": "text",
      "id": "min_price",
      "label": "Minimum price (£)",
      "default": "12.00"
    },
    {
      "type": "checkbox",
      "id": "show_finishing",
      "label": "Show finishing options",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Quote calculator"
    }
  ]
}
{% endschema %}
