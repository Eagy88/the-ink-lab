<section class="hero">
  <div class="hero__overlay"></div>
  {% if section.settings.background_image != blank %}
    <img src="{{ section.settings.background_image | image_url: width: 1920 }}" alt="" class="hero__bg" loading="eager">
  {% else %}
    <img src="{{ 'hero-background.png' | asset_url }}" alt="" class="hero__bg" loading="eager">
  {% endif %}
  <div class="container hero__content">
    <span class="hero__badge">{{ section.settings.badge_text }}</span>
    <h1 class="hero__title">{{ section.settings.heading }}</h1>
    <p class="hero__subtitle">{{ section.settings.subheading }}</p>
    <div class="hero__actions">
      {% if section.settings.button_1_text != blank %}
        <a href="{{ section.settings.button_1_link }}" class="btn btn--primary btn--lg">{{ section.settings.button_1_text }}</a>
      {% endif %}
      {% if section.settings.button_2_text != blank %}
        <a href="{{ section.settings.button_2_link }}" class="btn btn--outline btn--lg">{{ section.settings.button_2_text }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Premium Trade Print Quality"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Print that's easy to order and made to stand out."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Custom banners, window graphics, backlit displays, stickers and event printing with fast quotes and simple ordering."
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Button 1 text",
      "default": "Get Instant Quote"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Button 2 text",
      "default": "Upload Artwork"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
