<header class="header">
  <div class="container header__inner">
    <div class="header__spacer"></div>
    <a href="/" class="header__logo">
      {% if section.settings.logo != blank %}
        <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" class="header__logo-img" loading="eager">
      {% else %}
        <img src="{{ 'logo.png' | asset_url }}" alt="{{ shop.name }}" class="header__logo-img" loading="eager">
      {% endif %}
    </a>
    <div class="header__actions">
      <a href="/pages/contact" class="btn btn--outline btn--sm header__quote">Get Quote</a>
      <a href="{{ routes.cart_url }}" class="header__cart" aria-label="Basket">
        <svg class="header__cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span class="header__cart-count{% if cart.item_count == 0 %} is-empty{% endif %}" data-cart-count>{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    }
  ],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
