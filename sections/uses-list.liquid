<section class="uses-list">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    <div class="uses-list__grid">
      {% for block in section.blocks %}
        <div class="uses-list__item" {{ block.shopify_attributes }}>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="{{ settings.color_primary }}" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ block.settings.text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Uses list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Popular Uses"
    }
  ],
  "blocks": [
    {
      "type": "use",
      "name": "Use case",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Use case"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Uses list"
    }
  ]
}
{% endschema %}
