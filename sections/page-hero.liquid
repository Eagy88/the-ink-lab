<section class="page-hero">
  <div class="container">
    <h1 class="page-hero__title">{{ section.settings.heading | default: page.title }}</h1>
    {% if section.settings.description != blank %}
      <p class="page-hero__desc">{{ section.settings.description }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Page hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    }
  ],
  "presets": [
    {
      "name": "Page hero"
    }
  ]
}
{% endschema %}
