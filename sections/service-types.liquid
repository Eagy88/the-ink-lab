<section class="service-types">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.description != blank %}
      <p class="section-subheading">{{ section.settings.description }}</p>
    {% endif %}
    <div class="service-types__grid">
      {% for block in section.blocks %}
        <div class="service-types__card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 400 }}" alt="{{ block.settings.title }}" class="service-types__image" loading="lazy">
          {% endif %}
          <h3 class="service-types__title">{{ block.settings.title }}</h3>
          <p class="service-types__desc">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Service types",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service type",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service types"
    }
  ]
}
{% endschema %}
