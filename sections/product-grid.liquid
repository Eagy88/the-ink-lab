<section class="product-grid">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="section-subheading">{{ section.settings.subheading }}</p>
    {% endif %}
    <div class="product-grid__items">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="product-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="product-card__image">
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title }}" loading="lazy" width="600" height="400">
            </div>
          {% elsif block.settings.fallback_asset != blank %}
            <div class="product-card__image">
              <img src="{{ block.settings.fallback_asset | asset_url }}" alt="{{ block.settings.title }}" loading="lazy" width="600" height="400">
            </div>
          {% else %}
            <div class="product-card__image product-card__image--placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
          {% endif %}
          <div class="product-card__content">
            <h3 class="product-card__title">{{ block.settings.title }}</h3>
            {% if block.settings.description != blank %}
              <p class="product-card__desc">{{ block.settings.description }}</p>
            {% endif %}
            <span class="product-card__cta">View options &rarr;</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Product"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "fallback_asset",
          "label": "Fallback asset filename"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product grid",
      "settings": {
        "heading": "Our Products"
      },
      "blocks": [
        { "type": "product_card", "settings": { "title": "PVC Banners", "description": "Durable outdoor and indoor banners" } },
        { "type": "product_card", "settings": { "title": "Mesh Banners", "description": "Wind-resistant large format banners" } },
        { "type": "product_card", "settings": { "title": "Roller Banners", "description": "Portable event displays" } },
        { "type": "product_card", "settings": { "title": "Window Graphics", "description": "Frosted, clear and reverse printed" } },
        { "type": "product_card", "settings": { "title": "Backlit Graphics", "description": "Illuminated lightbox displays" } },
        { "type": "product_card", "settings": { "title": "Stickers & Labels", "description": "Custom cut stickers and labels" } }
      ]
    }
  ]
}
{% endschema %}
